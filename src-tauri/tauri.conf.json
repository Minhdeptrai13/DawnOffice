{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DawnOffice",
  "version": "0.1.0",
  "identifier": "com.binhminh.dawnoffice",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DawnOffice — Supercharged Office Suite",
        "width": 1360,
        "height": 860,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "WebView2Loader.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["docx", "doc"],
        "name": "Microsoft Word Document",
        "description": "DawnOffice Document File",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        "role": "Editor"
      },
      {
        "ext": ["xlsx", "xls", "csv"],
        "name": "Microsoft Excel Spreadsheet",
        "description": "DawnOffice Spreadsheet File",
        "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
        "role": "Editor"
      },
      {
        "ext": ["pptx", "ppt"],
        "name": "Microsoft PowerPoint Presentation",
        "description": "DawnOffice Presentation File",
        "mimeType": "application/vnd.openxmlformats-officedocument.presentationml.presentation",
        "role": "Editor"
      }
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": true
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0 | libwebkit2gtk-4.0-37", "libgtk-3-0", "libayatana-appindicator3-1"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
